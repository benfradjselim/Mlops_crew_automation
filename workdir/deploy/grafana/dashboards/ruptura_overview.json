{
  "apiVersion": 1,
  "uid": "ruptura-overview",
  "title": "Ruptura Workload Health",
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Health Score",
      "description": "Composite workload health [0-100]. Below 40 = poor, above 80 = excellent.",
      "targets": [
        {
          "expr": "ruptura_kpi_signals{signal=\"health_score\"}",
          "legendFormat": "{{namespace}}/{{kind}}/{{name}}",
          "refId": "A"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {"color": "red", "value": null},
          {"color": "yellow", "value": 40},
          {"color": "green", "value": 80}
        ]
      },
      "fieldConfig": {
        "defaults": {"min": 0, "max": 100}
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Stress and Fatigue",
      "description": "Stress = real-time load signal. Fatigue = accumulated burden over time.",
      "targets": [
        {
          "expr": "ruptura_kpi_signals{signal=\"stress\"}",
          "legendFormat": "stress {{namespace}}/{{name}}",
          "refId": "A"
        },
        {
          "expr": "ruptura_kpi_signals{signal=\"fatigue\"}",
          "legendFormat": "fatigue {{namespace}}/{{name}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Fused Rupture Index",
      "description": "FusedR = combined metric + log + trace rupture signal. Green <1, Yellow 1-3, Red >3.",
      "targets": [
        {
          "expr": "ruptura_kpi_signals{signal=\"fused_rupture_index\"}",
          "legendFormat": "{{namespace}}/{{name}}",
          "refId": "A"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 1},
          {"color": "red", "value": 3}
        ]
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Pressure and Contagion",
      "description": "Pressure = rate of deterioration (EWMA z-score). Contagion = error propagation from upstream services.",
      "targets": [
        {
          "expr": "ruptura_kpi_signals{signal=\"pressure\"}",
          "legendFormat": "pressure {{namespace}}/{{name}}",
          "refId": "A"
        },
        {
          "expr": "ruptura_kpi_signals{signal=\"contagion\"}",
          "legendFormat": "contagion {{namespace}}/{{name}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Anomaly Events",
      "description": "Total anomaly detections per workload and severity.",
      "targets": [
        {
          "expr": "ruptura_anomaly_total",
          "legendFormat": "{{host}} [{{severity}}]",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Throughput Collapse",
      "description": "Detects workloads going silent (circuit-breaker, crash-loop). 0=normal, 1=collapsed.",
      "targets": [
        {
          "expr": "ruptura_kpi_signals{signal=\"throughput\"}",
          "legendFormat": "{{namespace}}/{{name}}",
          "refId": "A"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {"color": "green", "value": null},
          {"color": "red", "value": 0.5}
        ]
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "query": "prometheus",
        "type": "datasource",
        "regex": "Prometheus",
        "hide": 0,
        "refresh": 1,
        "label": "Datasource"
      },
      {
        "name": "namespace",
        "query": "label_values(ruptura_kpi_signals, namespace)",
        "type": "query",
        "datasource": "$datasource",
        "hide": 0,
        "refresh": 1,
        "label": "Namespace"
      },
      {
        "name": "workload",
        "query": "label_values(ruptura_kpi_signals{namespace=\"$namespace\"}, name)",
        "type": "query",
        "datasource": "$datasource",
        "hide": 0,
        "refresh": 1,
        "label": "Workload"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "15s"
}
