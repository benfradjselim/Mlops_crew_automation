{
  "apiVersion": 1,
  "uid": "ruptura-overview",
  "title": "Ruptura Workload Health",
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Health Score",
      "description": "Composite workload health [0-100]. Below 40 = poor, above 80 = excellent.",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"health_score\"}",
          "legendFormat": "{{namespace}}/{{kind}}/{{workload}}",
          "refId": "A"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {"color": "red", "value": null},
          {"color": "yellow", "value": 40},
          {"color": "green", "value": 80}
        ]
      },
      "fieldConfig": {
        "defaults": {"min": 0, "max": 100}
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Fused Rupture Index",
      "description": "FusedR = combined metric + log + trace signal. Stable <1.5 · Warning 1.5–3 · Critical 3–5 · Emergency ≥5.",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"fused_rupture_index\"}",
          "legendFormat": "FusedR",
          "refId": "A"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 1.5},
          {"color": "orange", "value": 3},
          {"color": "red", "value": 5}
        ]
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Calibration Progress",
      "description": "0–100%. Predictions and actions are suppressed until 100% (first ~24h of data).",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"calibration_progress\"}",
          "legendFormat": "calibration",
          "refId": "A"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {"color": "red", "value": null},
          {"color": "yellow", "value": 50},
          {"color": "green", "value": 100}
        ]
      },
      "fieldConfig": {
        "defaults": {"min": 0, "max": 100, "unit": "percent"}
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Time to Critical",
      "description": "OLS projection: estimated minutes until HealthScore drops below 40. 0 = not degrading.",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"critical_eta_minutes\"}",
          "legendFormat": "ETA",
          "refId": "A"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {"color": "red", "value": null},
          {"color": "orange", "value": 15},
          {"color": "yellow", "value": 30},
          {"color": "green", "value": 60}
        ]
      },
      "fieldConfig": {
        "defaults": {"unit": "m", "noValue": "stable"}
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HealthScore Forecast",
      "description": "OLS trend projection: current score, projected score in 15min and 30min.",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"health_score\"}",
          "legendFormat": "now",
          "refId": "A"
        },
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"health_score_in_15min\"}",
          "legendFormat": "in 15min",
          "refId": "B"
        },
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"health_score_in_30min\"}",
          "legendFormat": "in 30min",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {"min": 0, "max": 100}
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Stress and Fatigue",
      "description": "Stress = real-time load signal. Fatigue = accumulated burden over time.",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"stress\"}",
          "legendFormat": "stress",
          "refId": "A"
        },
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"fatigue\"}",
          "legendFormat": "fatigue",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Pressure and Contagion",
      "description": "Pressure = rate of deterioration (EWMA z-score). Contagion = error propagation from upstream services.",
      "gridPos": {"x": 0, "y": 10, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"pressure\"}",
          "legendFormat": "pressure",
          "refId": "A"
        },
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"contagion\"}",
          "legendFormat": "contagion",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Resilience, Entropy and Velocity",
      "description": "Resilience = recovery speed. Entropy = behavioral unpredictability. Velocity = rate of HealthScore change.",
      "gridPos": {"x": 12, "y": 10, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"resilience\"}",
          "legendFormat": "resilience",
          "refId": "A"
        },
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"entropy\"}",
          "legendFormat": "entropy",
          "refId": "B"
        },
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"velocity\"}",
          "legendFormat": "velocity",
          "refId": "C"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "SLO Burn Velocity",
      "description": "Ratio of current error rate to allowed error rate. >1 = burning budget faster than allowed.",
      "gridPos": {"x": 0, "y": 16, "w": 8, "h": 4},
      "targets": [
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"slo_burn_velocity\"}",
          "legendFormat": "SLO burn",
          "refId": "A"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 0.5},
          {"color": "orange", "value": 1},
          {"color": "red", "value": 2}
        ]
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Blast Radius",
      "description": "Count of unique downstream workloads that depend on this one.",
      "gridPos": {"x": 8, "y": 16, "w": 8, "h": 4},
      "targets": [
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"blast_radius\"}",
          "legendFormat": "downstream deps",
          "refId": "A"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 5},
          {"color": "red", "value": 10}
        ]
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Recovery Debt",
      "description": "Near-misses (FusedR 2–3, recovered without rupture) in the last 7 days. High = fragile workload.",
      "gridPos": {"x": 16, "y": 16, "w": 8, "h": 4},
      "targets": [
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"recovery_debt\"}",
          "legendFormat": "near-misses",
          "refId": "A"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 3},
          {"color": "red", "value": 7}
        ]
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Throughput Collapse",
      "description": "Detects workloads going silent (circuit-breaker, crash-loop). 0 = normal, 1 = collapsed.",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 5},
      "targets": [
        {
          "expr": "ruptura_kpi{namespace=\"$namespace\",workload=\"$workload\",signal=\"throughput\"}",
          "legendFormat": "throughput",
          "refId": "A"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {"color": "green", "value": null},
          {"color": "red", "value": 0.5}
        ]
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Actions Fired",
      "description": "Ruptura actions executed or queued, broken down by type, tier and outcome.",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 5},
      "targets": [
        {
          "expr": "rate(rpt_actions_total[5m])",
          "legendFormat": "{{type}} tier{{tier}} {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Ingest Rate",
      "description": "Samples ingested per second by source (prometheus, otlp, grpc).",
      "gridPos": {"x": 0, "y": 25, "w": 12, "h": 5},
      "targets": [
        {
          "expr": "rate(rpt_ingest_samples_total[1m])",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "type": "table",
      "title": "Anomaly Events",
      "description": "Total anomaly detections per workload and severity.",
      "gridPos": {"x": 12, "y": 25, "w": 12, "h": 5},
      "targets": [
        {
          "expr": "ruptura_anomaly_total",
          "legendFormat": "{{host}} [{{severity}}]",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "query": "prometheus",
        "type": "datasource",
        "regex": "Prometheus",
        "hide": 0,
        "refresh": 1,
        "label": "Datasource"
      },
      {
        "name": "namespace",
        "query": "label_values(ruptura_kpi, namespace)",
        "type": "query",
        "datasource": "$datasource",
        "hide": 0,
        "refresh": 1,
        "label": "Namespace",
        "multi": false,
        "includeAll": false
      },
      {
        "name": "workload",
        "query": "label_values(ruptura_kpi{namespace=\"$namespace\"}, workload)",
        "type": "query",
        "datasource": "$datasource",
        "hide": 0,
        "refresh": 1,
        "label": "Workload",
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "15s"
}
