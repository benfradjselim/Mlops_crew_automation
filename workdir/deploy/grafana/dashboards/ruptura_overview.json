{
  "apiVersion": 1,
  "uid": "ruptura-overview",
  "title": "Ruptura Workload Health",
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Health Score",
      "targets": [
        {
          "expr": "ruptura_health_score",
          "refId": "A"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {"color": "red", "value": null},
          {"color": "yellow", "value": 40},
          {"color": "green", "value": 80}
        ]
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Stress and Fatigue",
      "targets": [
        {
          "expr": "ruptura_stress",
          "refId": "A"
        },
        {
          "expr": "ruptura_fatigue",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Rupture Index",
      "targets": [
        {
          "expr": "ruptura_rupture_index",
          "refId": "A"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 1},
          {"color": "red", "value": 3}
        ]
      }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Anomaly Total",
      "targets": [
        {
          "expr": "ruptura_anomaly_total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "text",
      "title": "Action Queue API",
      "options": {
        "mode": "markdown",
        "content": "### Action Queue API

This section provides an overview of the Action Queue API metrics. It helps monitor the health and performance of the API responsible for processing actions within the Ruptura system."
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "query": "prometheus",
        "type": "datasource",
        "regex": "Prometheus",
        "hide": 0,
        "refresh": 1,
        "label": "Datasource"
      },
      {
        "name": "namespace",
        "query": "label_values(kube_pod_info, namespace)",
        "type": "query",
        "datasource": "$datasource",
        "hide": 0,
        "refresh": 1,
        "label": "Namespace"
      }
    ]
  }
}